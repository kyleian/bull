# ── Bull scanner environment variables ─────────────────────────────────────
# Copy this file to .env and fill in values.
# All vars are optional unless you need email reporting.

# Scan behaviour
BULL_SCAN_MODE=all              # all | bullish | bearish | neutral
BULL_OUTPUT_FORMAT=console      # console | json | email
BULL_CONCURRENCY=10             # 1-50 concurrent fetch threads

# Data filters
BULL_HISTORY_DAYS=90            # days of price history to fetch
BULL_MIN_HISTORY_ROWS=52        # minimum rows needed (should be ≥50 for SMA-50)
BULL_MIN_BODY_PCT=0.8           # minimum candle body size %
BULL_MIN_VOLUME_RATIO=1.10      # minimum volume vs 20-day average
BULL_MIN_SIGNAL_SCORE=1.5       # minimum composite score (0-10)

# Email delivery (only required when BULL_OUTPUT_FORMAT=email)
BULL_GMAIL_ADDRESS=your@gmail.com
BULL_GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
BULL_TO_EMAIL=recipient@example.com   # defaults to BULL_GMAIL_ADDRESS if blank
